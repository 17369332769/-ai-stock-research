# ── 数据库 ───────────────────────────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me_locally
POSTGRES_DB=app
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://app:change_me_locally@db:5432/app

# ── OpenBB 统一数据网关 ──────────────────────────────────────────────────
# 业务代码只允许访问这个内部 REST；只有 services/openbb_extensions 可触达上游数据源。
OPENBB_BASE_URL=http://openbb:6900
OPENBB_TIMEOUT_SECONDS=30

# ── 应用 ─────────────────────────────────────────────────────────────────
APP_ENV=local
TZ=Asia/Shanghai
API_HOST=127.0.0.1
API_PORT=8000
LOG_LEVEL=INFO

# 行情新鲜度阈值（秒）：超过则标记 stale，禁止冒充实时
QUOTE_STALE_SECONDS=180

# ── 模型产物（容器内只读挂载）────────────────────────────────────────────
MODEL_ARTIFACT_ROOT=/models

# ── 分析 Agent（OpenAI 兼容协议；本地 Ollama 填 http://host.docker.internal:11434/v1）──
# 留空则 Agent 停用，接口返回 unknown 方向的模板摘要，不影响其他功能。
AGENT_BASE_URL=
AGENT_API_KEY=
AGENT_MODEL=

# ── 前端 ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000/api/v1

# ── 发布 ─────────────────────────────────────────────────────────────────
# 由 CI/发布脚本注入；没有提交 SHA 时发布必须失败（spec §19.1）
GIT_SHA=
